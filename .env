
#   1. Postgres credentials
#   2. MinIO / S3 credentials
#   3. MLflow configuration
#   4. Airflow configuration
#   5. BEAM-Net application settings


# =============================================================================
# 1. POSTGRESQL DATABASE
# =============================================================================
# Master credentials for the Postgres instance.
# Used by: postgres service, Airflow, MLflow, db-migrate, beam-net containers.

POSTGRES_USER=beam
POSTGRES_PASSWORD=beam_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Databases created by sql/init/01_create_databases.sql
POSTGRES_DB_AIRFLOW=airflow
POSTGRES_DB_MLFLOW=mlflow
POSTGRES_DB_METRICS=beam_metrics


# =============================================================================
# 2. MINIO (S3-COMPATIBLE OBJECT STORE)
# =============================================================================
# Stores: MLflow artifacts, datasets, generated reports.
# Console UI: http://localhost:9001 — credentials below.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000

# AWS SDK compatibility aliases (boto3 and mlflow read these)
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# Bucket names (created by minio-init service)
S3_BUCKET_MLFLOW=mlflow-artifacts
S3_BUCKET_DATA=beam-net-data
S3_BUCKET_RESULTS=beam-net-results


# =============================================================================
# 3. MLFLOW TRACKING SERVER
# =============================================================================
# Experiment tracking: metrics, params, artifacts, model binaries.
# UI: http://localhost:5000

MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://${S3_BUCKET_MLFLOW}/


# =============================================================================
# 4. AIRFLOW ORCHESTRATION
# =============================================================================
# Workflow orchestration for the BEAM-Net pipeline.
# UI: http://localhost:8080 — credentials AIRFLOW_ADMIN_USER / AIRFLOW_ADMIN_PASSWORD

AIRFLOW_PORT=8081
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@beam-net.local

# Fernet key for encrypting connection credentials in the Airflow metadata DB.
# To generate a new one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=

# Executor: LocalExecutor for single-machine dev; CeleryExecutor for prod
AIRFLOW_EXECUTOR=LocalExecutor

# Load example DAGs? false for clean environment, true for learning Airflow
AIRFLOW_LOAD_EXAMPLES=false


# =============================================================================
# 5. BEAM-NET APPLICATION
# =============================================================================
# Application-level configuration for the compute container.

# Full database URI for application code (src/db_logger.py)
BEAM_DB_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB_METRICS}

# Experiment configuration path (inside container)
BEAM_CONFIG_PATH=/workspace/configs/experiment.yaml

# Default compute device: auto | cpu | cuda
BEAM_DEVICE=auto


# =============================================================================
# 6. NETWORK
# =============================================================================
# Docker bridge network name — shared by all services.

COMPOSE_NETWORK=beam-net-network


# =============================================================================
# 7. BUILD METADATA (OPTIONAL)
# =============================================================================
# Used for versioning and traceability in CI/CD pipelines.

BEAM_VERSION=1.0.0
BEAM_BUILD_ENV=development